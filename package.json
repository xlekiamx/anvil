{
  "name": "anvil",
  "version": "0.1.0",
  "description": "Local multi-agent dev/review orchestration CLI",
  "type": "module",
  "bin": {
    "anvil": "./dist/bin/anvil.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin/anvil.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "ora": "^8.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "orchestrator",
    "multi-agent",
    "cli",
    "code-review",
    "automation"
  ],
  "license": "MIT"
}
